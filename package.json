{
  "$schema": "https://json.schemastore.org/package",
  "name": "@skilbjo/config-rc",
  "version": "0.0.1",
  "type": "module",
  "main": "index.js",
  "private": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skilbjo/config-rc.git"
  },
  "author": "skilbjo",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/skilbjo/config-rc/issues"
  },
  "homepage": "https://github.com/skilbjo/config-rc#readme",
  "scripts": {
    "prepare": "husky",
    "exec": "node",
    "eslint": "eslint .",
    "lint": "eslint",
    "lint:fix": "eslint --fix .",
    "depcheck": "depcheck",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare-npm": "jq 'del(.publishConfig) | . + { publishConfig: { registry: \"https://registry.npmjs.org/\", access: \"public\", provenance: true } }' package.json >package2.json && mv package2.json package.json"
  },
  "dependencies": {
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@typescript-eslint/parser": "8.63.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-n": "18.2.2",
    "eslint-plugin-perfectionist": "5.9.1",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-security": "4.0.1",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "typescript-eslint": "8.62.1"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-angular": "21.2.0",
    "@types/node": "26.1.0",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "depcheck": "1.4.7",
    "husky": "9.1.7"
  },
  "exports": {
    ".": "./index.js",
    "./tsconfig.json": "./tsconfig.json",
    "./*": "./*"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-angular"
    ]
  },
  "engines": {
    "node": ">=24.14.1"
  }
}
